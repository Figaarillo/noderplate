NODE_ENV=development
HTTP_RUNTIME=fastify
PORT=8080
ORM=prisma

# Database - REQUIRED
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASS=your_db_password
DATABASE_NAME=noderplate
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/noderplate

# JWT - REQUIRED
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email (optional - uses mock if not configured)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@noderplate.local
